{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        }
    ],
    "routes": [
        {
            "src": "/analyze",
            "dest": "/api/index.py"
        },
        {
            "src": "/career-guidance",
            "dest": "/api/index.py"
        },
        {
            "src": "/resume-check",
            "dest": "/api/index.py"
        },
        {
            "src": "/health",
            "dest": "/api/index.py"
        },
        {
            "src": "/verify-company",
            "dest": "/api/index.py"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/assets/$1"
        },
        {
            "src": "/manifest.json",
            "dest": "/manifest.json"
        },
        {
            "src": "/sw.js",
            "dest": "/sw.js"
        },
        {
            "src": "/(.*)\\.html",
            "dest": "/$1.html"
        },
        {
            "src": "/",
            "dest": "/index.html"
        }
    ]
}